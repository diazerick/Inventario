@using WebProductos.Models

@model List<E_Producto>

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Consulta</title>
    <!--Agregando los archivos de bootstrap-->
    <link href="~/Content/bootstrap.css" rel="stylesheet" />
    <script src="~/Scripts/bootstrap.js"></script>
</head>
<body>
    <div class="container">
        <h1>Inventario</h1>

        <a href="/Producto/Agregar" class="btn btn-dark mb-3">Agregar</a>

        @if (TempData["mensaje"] != null)
        {
            <div class="alert alert-success">
                @TempData["mensaje"]
            </div>
        }

        @if (TempData["error"] != null)
        {
            <div class="alert alert-danger">
                Ocurrio un error: @TempData["error"]
            </div>
        }

        <table class="table table-success table-bordered table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Descripcion</th>
                    <th>Precio</th>
                    <th>Fecha Ingreso</th>
                    <th>Fecha Caducidad</th>
                    <th>¿Esta Disponible?</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (E_Producto producto in Model)
                {
                    <tr>
                        <td>@producto.IdProducto</td>
                        <td>@producto.Descripcion</td>
                        <td>@producto.Precio</td>
                        <td>@producto.FechaIngreso.ToString("dd/MM/yyyy") </td>
                        <td>@producto.FechaCaducidad.ToString("dd/MM/yyyy")</td>
                        <td>@Html.Raw(producto.DisponibleHtml)  </td>
                        <td>
                            <a href="/Producto/Editar?idProducto=@producto.IdProducto" class="btn btn-info">Editar</a>

                            <a href="/Producto/Eliminar?idProducto=@producto.IdProducto" class="btn btn-danger">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</body>
</html>
